# ─── Node-specific settings ──────────────────────────────────────────
# Uncomment the block for this node and comment out the others.

# --- Node 1 ---
NODE_NAME=pg-node1
NODE_IP=172.16.0.201
ETCD_NAME=etcd1
KEEPALIVED_STATE=MASTER
KEEPALIVED_PRIORITY=150

# --- Node 2 ---
# NODE_NAME=pg-node2
# NODE_IP=172.16.0.202
# ETCD_NAME=etcd2
# KEEPALIVED_STATE=BACKUP
# KEEPALIVED_PRIORITY=100

# --- Node 3 ---
# NODE_NAME=pg-node3
# NODE_IP=172.16.0.203
# ETCD_NAME=etcd3
# KEEPALIVED_STATE=BACKUP
# KEEPALIVED_PRIORITY=50

# ─── PostgreSQL memory tuning (adjust per node's RAM) ────────────────
# Primary (50GB RAM):
PG_SHARED_BUFFERS=10GB
PG_EFFECTIVE_CACHE_SIZE=40GB
PG_WORK_MEM=64MB
PG_MAINTENANCE_WORK_MEM=2GB

# Replica with less RAM — example for 32GB node:
# PG_SHARED_BUFFERS=6GB
# PG_EFFECTIVE_CACHE_SIZE=24GB
# PG_WORK_MEM=32MB
# PG_MAINTENANCE_WORK_MEM=1GB

# Replica with less RAM — example for 16GB node:
# PG_SHARED_BUFFERS=3GB
# PG_EFFECTIVE_CACHE_SIZE=12GB
# PG_WORK_MEM=16MB
# PG_MAINTENANCE_WORK_MEM=512MB

# ─── Network ────────────────────────────────────────────────────────
KEEPALIVED_INTERFACE=ens19

# ─── Passwords (CHANGE ALL OF THESE) ────────────────────────────────
POSTGRES_PASSWORD=change_me_superuser
REPLICATION_PASSWORD=change_me_replication
REWIND_PASSWORD=change_me_rewind
ADEMPIERE_PASSWORD=change_me_adempiere
KEEPALIVED_PASSWORD=change_me_keepalived
